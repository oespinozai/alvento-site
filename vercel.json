{
  "cleanUrls": true,
  "trailingSlash": true,
  "rewrites": [
    { "source": "/report/:token/", "destination": "/reports/:token" },
    { "source": "/report/:token", "destination": "/reports/:token" },
    { "source": "/tools", "destination": "/tools.html" },
    { "source": "/tools/pdf-to-markdown", "destination": "/tools/pdf-to-markdown/index.html" },
    { "source": "/tools/sop-to-checklist", "destination": "/tools/sop-to-checklist/index.html" },
    { "source": "/tools/psbar-statement-generator", "destination": "/tools/psbar-statement-generator/index.html" },
    { "source": "/tools/mdr-psur-outline-generator", "destination": "/tools/mdr-psur-outline-generator/index.html" },
    { "source": "/tools/mdr-technical-file-index", "destination": "/tools/mdr-technical-file-index/index.html" },
    { "source": "/tools/cpd-tracker", "destination": "/tools/cpd-tracker/index.html" },
    { "source": "/tools/udi-decoder", "destination": "/tools/udi-decoder/index.html" },
    { "source": "/tools/mdr-class-check", "destination": "/tools/mdr-class-check/index.html" },
    { "source": "/website-audit", "destination": "/website-audit.html" },
    { "source": "/RegalMail", "destination": "/email-plugin.html" },
    { "source": "/score-api", "destination": "/score-api.html" },
    { "source": "/aeo", "destination": "/aeo.html" }
  ],
  "redirects": [
    { "source": "/seo-audit", "destination": "/website-audit", "permanent": true },
    { "source": "/seo-audit/", "destination": "/website-audit", "permanent": true }
  ],
  "functions": {
    "api/audit.js": { "maxDuration": 15 }
  }
}
